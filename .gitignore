# ─── Secretos ─────────────────────────────────────────────────────────────────
.env

# ─── Datos generados en runtime ───────────────────────────────────────────────
# Usar glob (* no trailing slash) para que .gitkeep siga siendo rastreado
data/raw/*
data/processed/*

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ─── Tests y linting ──────────────────────────────────────────────────────────
.pytest_cache/
.ruff_cache/

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
.chroma/

# ─── Entornos virtuales ───────────────────────────────────────────────────────
.venv/
venv/

# ─── Build ────────────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/

# ─── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

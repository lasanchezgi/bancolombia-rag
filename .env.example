# === LLM & Embeddings ===
OPENAI_API_KEY=sk-...

# === ChromaDB ===
# Usar "local" para desarrollo local (PersistentClient en .chroma/)
# Usar el hostname del servicio para Docker (ej: "chromadb")
CHROMA_HOST=local
CHROMA_PORT=8000
CHROMA_COLLECTION=bancolombia_kb

# === MCP Server ===
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
MCP_TRANSPORT=stdio
MCP_SERVER_SCRIPT=src/mcp_server/server.py

# === Scraper ===
BANCOLOMBIA_BASE_URL=https://www.bancolombia.com/personas
MAX_PAGES=80

# === Pipeline ===
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

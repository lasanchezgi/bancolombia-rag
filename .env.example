# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Clave de API de OpenAI (requerida para embeddings y generación de respuestas)
OPENAI_API_KEY=sk-...

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
# Host del servidor ChromaDB (usa 'chromadb' cuando corre dentro de Docker)
CHROMA_HOST=localhost
# Puerto HTTP de ChromaDB
CHROMA_PORT=8000

# ─── MCP Server ───────────────────────────────────────────────────────────────
# Host del servidor FastMCP (usa 'mcp_server' dentro de Docker)
MCP_SERVER_HOST=localhost
# Puerto de escucha del servidor MCP
MCP_SERVER_PORT=8080

# ─── Scraper ──────────────────────────────────────────────────────────────────
# URL base del sitio de Bancolombia a indexar
BANCOLOMBIA_BASE_URL=https://www.bancolombia.com
# Número máximo de páginas a crawlear
MAX_PAGES=50

# ─── Pipeline ─────────────────────────────────────────────────────────────────
# Tamaño de cada chunk en caracteres
CHUNK_SIZE=512
# Solapamiento entre chunks consecutivos en caracteres
CHUNK_OVERLAP=64

# ─── Retrieval ────────────────────────────────────────────────────────────────
# Número de documentos a recuperar por consulta
TOP_K_RESULTS=5
